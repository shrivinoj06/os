#include <stdio.h>
#include <string.h>

#define MAX_FILES 10
#define MAX_USERS 5
#define NAME_LEN 20

// Single-Level Directory
char singleLevel[MAX_FILES][NAME_LEN];
int fileCount = 0;

// Two-Level Directory
char users[MAX_USERS][NAME_LEN];
char twoLevel[MAX_USERS][MAX_FILES][NAME_LEN];
int userFileCount[MAX_USERS] = {0};
int userCount = 0;

// ---------------- SINGLE LEVEL ----------------

// Check duplicate file
int isDuplicateSingle(char filename[]) {
    for (int i = 0; i < fileCount; i++) {
        if (strcmp(singleLevel[i], filename) == 0)
            return 1;
    }
    return 0;
}

void createSingleLevelFile() {
    if (fileCount >= MAX_FILES) {
        printf("Directory is full!\n");
        return;
    }

    char filename[NAME_LEN];
    printf("Enter filename: ");
    scanf("%19s", filename);

    if (isDuplicateSingle(filename)) {
        printf("File already exists!\n");
        return;
    }

    strcpy(singleLevel[fileCount], filename);
    fileCount++;
    printf("File created successfully.\n");
}

void displaySingleLevelFiles() {
    if (fileCount == 0) {
        printf("No files in directory.\n");
        return;
    }

    printf("Files in Single-Level Directory:\n");
    for (int i = 0; i < fileCount; i++) {
        printf("%s\n", singleLevel[i]);
    }
}

// ---------------- TWO LEVEL ----------------

// Check duplicate user
int isDuplicateUser(char username[]) {
    for (int i = 0; i < userCount; i++) {
        if (strcmp(users[i], username) == 0)
            return 1;
    }
    return 0;
}

// Find user index
int findUser(char username[]) {
    for (int i = 0; i < userCount; i++) {
        if (strcmp(users[i], username) == 0)
            return i;
    }
    return -1;
}

// Check duplicate file for a user
int isDuplicateTwoLevel(int userIndex, char filename[]) {
    for (int i = 0; i < userFileCount[userIndex]; i++) {
        if (strcmp(twoLevel[userIndex][i], filename) == 0)
            return 1;
    }
    return 0;
}

void createUser() {
    if (userCount >= MAX_USERS) {
        printf("Maximum users reached!\n");
        return;
    }

    char username[NAME_LEN];
    printf("Enter username: ");
    scanf("%19s", username);

    if (isDuplicateUser(username)) {
        printf("User already exists!\n");
        return;
    }

    strcpy(users[userCount], username);
    userCount++;
    printf("User created successfully.\n");
}

void createTwoLevelFile() {
    char username[NAME_LEN];
    printf("Enter username: ");
    scanf("%19s", username);

    int userIndex = findUser(username);

    if (userIndex == -1) {
        printf("User not found!\n");
        return;
    }

    if (userFileCount[userIndex] >= MAX_FILES) {
        printf("User directory is full!\n");
        return;
    }

    char filename[NAME_LEN];
    printf("Enter filename: ");
    scanf("%19s", filename);

    if (isDuplicateTwoLevel(userIndex, filename)) {
        printf("File already exists for this user!\n");
        return;
    }

    strcpy(twoLevel[userIndex][userFileCount[userIndex]], filename);
    userFileCount[userIndex]++;
    printf("File created successfully.\n");
}

void displayTwoLevelFiles() {
    if (userCount == 0) {
        printf("No users available.\n");
        return;
    }

    for (int i = 0; i < userCount; i++) {
        printf("\nUser: %s\n", users[i]);

        if (userFileCount[i] == 0) {
            printf("  No files.\n");
        } else {
            for (int j = 0; j < userFileCount[i]; j++) {
                printf("  %s\n", twoLevel[i][j]);
            }
        }
    }
}

// ---------------- MAIN ----------------

int main() {
    int choice;

    while (1) {
        printf("\n--- File Organization Techniques ---\n");
        printf("1. Create File (Single-Level)\n");
        printf("2. Display Files (Single-Level)\n");
        printf("3. Create User (Two-Level)\n");
        printf("4. Create File (Two-Level)\n");
        printf("5. Display User Files (Two-Level)\n");
        printf("6. Exit\n");
        printf("Enter choice: ");

        if (scanf("%d", &choice) != 1) {
            printf("Invalid input!\n");
            return 0;
        }

        switch (choice) {
            case 1:
                createSingleLevelFile();
                break;
            case 2:
                displaySingleLevelFiles();
                break;
            case 3:
                createUser();
                break;
            case 4:
                createTwoLevelFile();
                break;
            case 5:
                displayTwoLevelFiles();
                break;
            case 6:
                printf("Exiting program...\n");
                return 0;
            default:
                printf("Invalid choice! Try again.\n");
        }
    }

    return 0;
}
