#include <stdio.h>

#define MAX_FRAMES 10
#define MAX_REFERENCES 100

int frames[MAX_FRAMES];
int freq[MAX_FRAMES];
int time[MAX_FRAMES];

int pageFaults = 0, frameCount, referenceCount;

// Initialize frames
void initFrames() {
    for (int i = 0; i < frameCount; i++) {
        frames[i] = -1;
        freq[i] = 0;
        time[i] = -1;
    }
    pageFaults = 0;
}

// Find page
int findPage(int page) {
    for (int i = 0; i < frameCount; i++) {
        if (frames[i] == page)
            return i;
    }
    return -1;
}

// Display frames
void displayFrames() {
    for (int i = 0; i < frameCount; i++) {
        if (frames[i] == -1)
            printf("- ");
        else
            printf("%d ", frames[i]);
    }
    printf("\n");
}

// FIFO
void fifo(int ref[]) {
    int head = 0;
    initFrames();

    for (int i = 0; i < referenceCount; i++) {
        int page = ref[i];

        if (findPage(page) == -1) {
            frames[head] = page;
            head = (head + 1) % frameCount;
            pageFaults++;
        }
        displayFrames();
    }

    printf("Total Page Faults (FIFO): %d\n", pageFaults);
}

// LRU
void lru(int ref[]) {
    initFrames();

    for (int i = 0; i < referenceCount; i++) {
        int page = ref[i];
        int index = findPage(page);

        if (index != -1) {
            time[index] = i;
        } else {
            int lruIndex = -1;

            for (int j = 0; j < frameCount; j++) {
                if (frames[j] == -1) {
                    lruIndex = j;
                    break;
                }
            }

            if (lruIndex == -1) {
                lruIndex = 0;
                for (int j = 1; j < frameCount; j++) {
                    if (time[j] < time[lruIndex])
                        lruIndex = j;
                }
            }

            frames[lruIndex] = page;
            time[lruIndex] = i;
            pageFaults++;
        }
        displayFrames();
    }

    printf("Total Page Faults (LRU): %d\n", pageFaults);
}

// LFU
void lfu(int ref[]) {
    initFrames();

    for (int i = 0; i < referenceCount; i++) {
        int page = ref[i];
        int index = findPage(page);

        if (index != -1) {
            freq[index]++;
        } else {
            int lfuIndex = -1;

            for (int j = 0; j < frameCount; j++) {
                if (frames[j] == -1) {
                    lfuIndex = j;
                    break;
                }
            }

            if (lfuIndex == -1) {
                lfuIndex = 0;
                for (int j = 1; j < frameCount; j++) {
                    if (freq[j] < freq[lfuIndex])
                        lfuIndex = j;
                }
            }

            frames[lfuIndex] = page;
            freq[lfuIndex] = 1;
            pageFaults++;
        }
        displayFrames();
    }

    printf("Total Page Faults (LFU): %d\n", pageFaults);
}

// Main
int main() {
    int ref[MAX_REFERENCES], choice;

    printf("Enter number of page references: ");
    scanf("%d", &referenceCount);

    printf("Enter the reference string:\n");
    for (int i = 0; i < referenceCount; i++) {
        scanf("%d", &ref[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &frameCount);

    printf("\n1. FIFO\n2. LRU\n3. LFU\nEnter choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            fifo(ref);
            break;
        case 2:
            lru(ref);
            break;
        case 3:
            lfu(ref);
            break;
        default:
            printf("Invalid choice!\n");
    }

    return 0;
}
